#!/bin/sh
# Pre-push check: type check + lint + format

echo "Running pre-push checks..."

echo "🔍 Type checking..."
npx tsc --noEmit
if [ $? -ne 0 ]; then
  echo "❌ TypeScript check failed. Push aborted."
  exit 1
fi

echo "🧹 Linting..."
npm run lint
if [ $? -ne 0 ]; then
  echo "❌ Lint failed. Push aborted."
  exit 1
fi

echo "✨ Checking formatting..."
npx prettier --check .
if [ $? -ne 0 ]; then
  echo "❌ Code formatting check failed. Run 'npx prettier --write .' to fix."
  exit 1
fi

echo "✅ Pre-push checks passed."
exit 0
